{
  "compilerOptions": {
    "strict": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": { "~/*": ["./*"], "@/*": ["./*"] }
  },
  "exclude": ["node_modules", ".nuxt", "dist"]
}
